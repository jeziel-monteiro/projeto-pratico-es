{
  "name": "porto-certo-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:init:local": "/usr/lib/postgresql/16/bin/initdb -D .postgres-data -A trust",
    "db:start:local": "/usr/lib/postgresql/16/bin/pg_ctl -D .postgres-data -l .postgres-data/postgres.log -o \"-p 55432 -k /tmp\" start",
    "db:stop:local": "/usr/lib/postgresql/16/bin/pg_ctl -D .postgres-data stop",
    "db:status:local": "/usr/lib/postgresql/16/bin/pg_ctl -D .postgres-data status",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "prisma": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
